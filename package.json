{
  "name": "repopilot",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "scripts": {
    "dev:web": "npm run dev -w @repopilot/web",
    "build:web": "npm run build -w @repopilot/web",
    "preview:web": "npm run preview -w @repopilot/web",
    "test:web": "npm run test -w @repopilot/web",
    "test:web:e2e": "npm run test:e2e -w @repopilot/web",
    "lint:web": "npm run lint -w @repopilot/web",
    "typecheck:web": "npm run typecheck -w @repopilot/web",
    "test:api": "pytest test -q",
    "test": "npm run test:api && npm run test:web",
    "dev:api": "uvicorn backend.main:app --reload --port 19876 --app-dir services/api",
    "dev:agent": "uvicorn agent_runtime.main:app --reload --port 19877 --app-dir services/agent"
  }
}
